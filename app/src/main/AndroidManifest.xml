<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.gullafshan.workoutplans">

    <!-- Internet permission for API access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme._7minuteWorkoutPlans">

        <activity
            android:name=".NotesActivity"
            android:exported="false" />
        <activity
            android:name=".ApiDataActivity"
            android:exported="false" /> <!-- Splash Screen (Optional, still shown first) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true" /> <!-- Landing / Main Hub -->
        <activity
            android:name=".LandingActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true" /> <!-- Registration -->
        <activity
            android:name=".RegistrationActivity"
            android:exported="true" /> <!-- Forgot Password -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="true" /> <!-- Reset Password -->
        <activity
            android:name=".ResetPasswordActivity"
            android:exported="true" /> <!-- Workout Timer -->
        <activity
            android:name=".WorkoutTimerActivity"
            android:exported="true" />
    </application>

</manifest>
